{
  "name": "@lunarq/frontend-shared",
  "version": "0.1.6",
  "description": "Shared frontend platform assets for LunarQ applications",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/report.css": "./dist/components/report.css",
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./maintenance": {
      "types": "./dist/maintenance/index.d.ts",
      "import": "./dist/maintenance/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./react-fields": {
      "types": "./dist/react-fields.d.ts",
      "import": "./dist/react-fields.js"
    },
    "./theme/index.css": "./dist/theme/index.css",
    "./components/index.css": "./dist/components/index.css",
    "./admin/index.css": "./dist/admin/index.css",
    "./maintenance/index.css": "./dist/maintenance/index.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "node ./scripts/clean-dist.mjs && tsc --project tsconfig.json && node ./scripts/copy-assets.mjs",
    "prepare": "npm run build",
    "test": "node scripts/run-tests.mjs",
    "showcase:dev": "npm --prefix showcase run dev",
    "showcase:build": "npm --prefix showcase run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
